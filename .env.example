# myBay - Environment Variables
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env

# ============================================
# AI Backend (choose one)
# ============================================
# Option 1: OpenAI (cloud, paid, best quality + web search)
OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE
# OPENAI_VISION_MODEL=gpt-5.4-nano-2026-03-17

# Option 2: Ollama (local, free, private — no account needed)
# Install: brew install ollama && ollama serve && ollama pull llava:7b
# OLLAMA_VISION_MODEL=llava:7b
# OLLAMA_URL=http://localhost:11434

# ============================================
# eBay Sandbox (for testing)
# ============================================
EBAY_SANDBOX_APP_ID=your-sandbox-app-id
EBAY_SANDBOX_CERT_ID=your-sandbox-cert-id
EBAY_SANDBOX_DEV_ID=your-sandbox-dev-id

# ============================================
# eBay Production (for real listings)
# ============================================
EBAY_PRODUCTION_APP_ID=your-production-app-id
EBAY_PRODUCTION_CERT_ID=your-production-cert-id
EBAY_PRODUCTION_DEV_ID=your-production-dev-id

# ============================================
# Optional
# ============================================
# NGROK_AUTHTOKEN=your-ngrok-token  # Only needed for remote camera access
